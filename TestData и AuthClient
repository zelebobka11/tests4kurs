package ru.conscious;

import io.restassured.http.ContentType;

import static io.restassured.RestAssured.given;

public class AuthClient {

  public static void register(String login, String email, String password) {
    given()
      .contentType(ContentType.JSON)
      .body(new RegisterReq(login, email, password))
    .when()
      .post("/api/auth/register")
    .then()
      .statusCode(201);
  }

  public static String loginAndGetToken(String login, String password) {
    return given()
      .contentType(ContentType.JSON)
      .body(new LoginReq(login, password))
    .when()
      .post("/api/auth/login")
    .then()
      .statusCode(200)
      .extract()
      .path("token");
  }

  public record RegisterReq(String login, String email, String password) {}
  public record LoginReq(String login, String password) {}
}
